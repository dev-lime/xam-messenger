# XAM Messenger Server Configuration
# Скопируйте этот файл в .env и настройте параметры

# ============================================
# СЕТЬ
# ============================================

# Хост для прослушивания (по умолчанию: 0.0.0.0)
XAM_HOST=0.0.0.0

# Порт для прослушивания (по умолчанию: 8080)
XAM_PORT=8080

# ============================================
# БАЗА ДАННЫХ
# ============================================

# Путь к базе данных SQLite
# По умолчанию: ~/.config/xam-messenger/xam.db
XAM_DB_PATH=~/.config/xam-messenger/xam.db

# ============================================
# ФАЙЛЫ
# ============================================

# Директория для загруженных файлов
# По умолчанию: ~/.local/share/xam-messenger/files
XAM_UPLOAD_DIR=~/.local/share/xam-messenger/files

# Максимальный размер файла в байтах (по умолчанию: 100MB)
MAX_FILE_SIZE=104857600

# ============================================
# CORS
# ============================================

# Разрешённые origin (по умолчанию: * - все)
# Для ограничения укажите список через запятую:
# CORS_ORIGINS=https://example.com,https://app.example.com
CORS_ORIGINS=*

# ============================================
# RATE LIMITING
# ============================================

# Лимит запросов в минуту на один IP (по умолчанию: 100)
# Уменьшите значение для более строгого ограничения
# Пример: RATE_LIMIT=50 для 50 запросов в минуту
RATE_LIMIT=100

# ============================================
# WEBSOCKET
# ============================================

# Размер канала для широковещательных сообщений (по умолчанию: 1000)
BROADCAST_CHANNEL_SIZE=1000

# ============================================
# ЛОГИРОВАНИЕ
# ============================================

# Уровень логирования: trace, debug, info, warn, error
# По умолчанию: info
RUST_LOG=info

# Примеры:
# RUST_LOG=debug                    # Отладочный режим
# RUST_LOG=xam_server=debug         # Только лог сервера
# RUST_LOG=debug,actix_web=warn     # Debug с подавлением actix

# Максимальная длина имени пользователя
MAX_NAME_LENGTH=50

# Максимальная длина текстового сообщения
MAX_MESSAGE_LENGTH=10000

# Максимальная длина имени файла
MAX_FILE_NAME_LENGTH=255
