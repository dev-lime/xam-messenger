{
  "package": {
    "productName": "Xam Messenger",
    "version": "1.0.0"
  },
  "build": {
    "distDir": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "tauri": {
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.xam.messenger",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/icon.png"
      ]
    },
    "windows": [
      {
        "title": "Xam Messenger",
        "width": 900,
        "height": 600,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
