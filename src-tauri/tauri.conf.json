{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Xam Messenger",
	"version": "1.0.0",
	"identifier": "com.xam.messenger",
	"build": {
		"frontendDist": "../src",
		"devUrl": "http://localhost:1420/",
		"beforeDevCommand": "npm run dev:server",
		"beforeBuildCommand": ""
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"title": "Xam Messenger",
				"width": 900,
				"height": 600,
				"minWidth": 700,
				"minHeight": 500,
				"resizable": true,
				"fullscreen": false,
				"center": true,
				"dragDropEnabled": true
			}
		],
		"security": {
			"csp": null,
			"capabilities": ["main-capability"]
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico",
			"icons/icon.png"
		]
	}
}