{
  "name": "xam-messenger-client",
  "version": "1.0.0",
  "description": "LAN Messenger Client Tests",
  "private": true,
  "scripts": {
    "test": "jest --coverage --transformIgnorePatterns 'node_modules/' --testPathIgnorePatterns 'integration.test.js'",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageReporters=html",
    "test:integration": "jest --config jest.integration.config.js",
    "test:all": "npm test && npm run test:integration",
    "cleanup:test-db": "node scripts/cleanup-test-db.js",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "tauri": "tauri",
    "dev:server": "node scripts/dev-server.js",
    "prepare": "npx simple-git-hooks"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/user-event": "^14.5.2",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "simple-git-hooks": "^2.13.1",
    "ws": "^8.14.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run lint && npm test -- --silent --bail"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/src/__tests__/setup.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "integration.test.js"
    ],
    "collectCoverageFrom": [
      "<rootDir>/src/**/*.js",
      "!<rootDir>/src/__tests__/**"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/__tests__/"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(node_modules)/)"
    ]
  }
}
