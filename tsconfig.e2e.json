{
	"compilerOptions": {
		"target": "ES2020",
		"module": "commonjs",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"outDir": "./e2e-dist",
		"rootDir": ".",
		"noEmit": true,
		"types": ["node", "@playwright/test"]
	},
	"include": ["e2e/**/*.ts", "playwright.config.ts"],
	"exclude": ["node_modules"]
}
